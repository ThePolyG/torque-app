# ─────────────────────────────────────────────────────────────────────────────
# torque-app — environment variables
# Copy to .env.local for local dev. In production, set these in the Vercel
# dashboard (Project → Settings → Environment Variables).
# .env / .env.local are gitignored — never commit real keys.
# ─────────────────────────────────────────────────────────────────────────────

# ── Existing (already used by /api/chat and /api/send-transcript) ────────────
ANTHROPIC_API_KEY=
RESEND_API_KEY=

# ── Create-Profile wizard ────────────────────────────────────────────────────

# Where new-profile notification emails go. Defaults to chris@thepolyg.com if unset.
LEAD_NOTIFY_EMAIL=chris@thepolyg.com

# Google Maps JavaScript API key — PUBLIC (client-side), restrict it by domain
# (thepolyg.com + localhost for dev). Enable "Maps JavaScript API" + "Geocoding
# API" in your Google Cloud project, attach billing, then create the key.
# If this is blank the map picker shows a graceful "pending setup" placeholder —
# the form still works, you just don't get the pin-drop yet.
NEXT_PUBLIC_GOOGLE_MAPS_KEY=

# Google service account — for writing leads to a Google Sheet.
# Paste the FULL service-account JSON (the whole {...} blob) OR its base64.
# The service account needs the "Google Sheets API" enabled, and the target
# sheet must be SHARED with the service account's client_email (Editor).
# If blank, leads still email you — they just don't auto-append to the sheet.
GOOGLE_SERVICE_ACCOUNT_JSON=

# The Google Sheet ID where leads get appended (the long string in the sheet URL).
PMG_LEADS_SHEET_ID=

# Tab name inside that sheet. Defaults to "Leads" if unset.
PMG_LEADS_SHEET_TAB=Leads
